#Identifiant de la base de données

DB_USER="username"
#Mot de passe de la base de données

DB_PASSWORD="password"
#nom de la base de données

DB_NAME="db_name"
#Adresse de l'hôte de la base de données (ex: localhost ou db pour Docker)

DB_HOST="db"

#connexion à la base de données de façon synchrone
database_url=" mysql+pymysql://user:password@host:port/db_name"

#connexion à la base de données de façon Asynchrone
Async_database_url=" mysql+aiomysql://user:password@host:port/db_name"